{
  "name": "mighty-max",
  "displayName": "Mighty Max",
  "description": "MiniMax M-series language models for VS Code Chat (BYOK)",
  "version": "0.2.1",
  "publisher": "greysquirr3l",
  "license": "MIT",
  "icon": "assets/img/mighty_max_head.png",
  "engines": {
    "vscode": "^1.104.0",
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/greysquirr3l/mighty-max.git"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "chat",
    "ai",
    "minimax",
    "m3",
    "language-models",
    "byok",
    "bring-your-own-key",
    "copilot",
    "agent",
    "mcp",
    "model-context-protocol",
    "llm"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mightyMax.manage",
        "title": "Manage Mighty Max (Set API Key)",
        "category": "Mighty Max"
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "minimax",
        "displayName": "Mighty Max (MiniMax)",
        "managementCommand": "mightyMax.manage"
      }
    ],
    "configuration": {
      "title": "Mighty Max",
      "properties": {
        "mightyMax.baseUrl": {
          "type": "string",
          "default": "https://api.minimax.io",
          "description": "MiniMax API base URL. The API key is never stored here — it lives in SecretStorage.",
          "scope": "application"
        },
        "mightyMax.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log level for Mighty Max. Logs never contain the API key, Authorization header, or request/response bodies.",
          "scope": "window"
        },
        "mightyMax.enableSmartToolFiltering": {
          "type": "boolean",
          "default": true,
          "description": "Enable smart tool filtering to work around M3's limitations with large tool sets (80+ tools). When enabled, only the most relevant tools are sent to the model based on your prompt and usage history.",
          "scope": "window"
        },
        "mightyMax.maxTools": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 100,
          "description": "Maximum number of tools to send to the model when smart filtering is enabled. M3 works best with 20-40 tools. Set higher if you have a small tool set or want to disable the limit.",
          "scope": "window"
        },
        "mightyMax.alwaysIncludeTools": {
          "type": "array",
          "default": [
            "read_file",
            "write_file",
            "edit_file",
            "bash",
            "grep",
            "glob"
          ],
          "items": {
            "type": "string"
          },
          "description": "Tool names that should always be included regardless of relevance scoring. Common file and code operations are included by default.",
          "scope": "window"
        },
        "mightyMax.toolFilterStrategy": {
          "type": "string",
          "enum": [
            "relevance",
            "usage",
            "hybrid"
          ],
          "default": "hybrid",
          "enumDescriptions": [
            "Filter based on semantic relevance to the current prompt (keyword matching)",
            "Filter based on historical usage patterns (frequently-used tools prioritized)",
            "Combine relevance and usage scoring for balanced filtering"
          ],
          "description": "Strategy for selecting which tools to include when filtering is enabled.",
          "scope": "window"
        },
        "mightyMax.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Optional system prompt sent on every M3 request. When empty, Mighty Max uses a short preamble that nudges M3 to plan before the first tool call. The prompt is sanitized for UTF-16 surrogate code points and sent with `cache_control: ephemeral` so it is reused across requests.",
          "scope": "window"
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "restrictedConfigurations": [
        "mightyMax.baseUrl"
      ]
    },
    "virtualWorkspaces": {
      "supported": "limited"
    }
  },
  "scripts": {
    "clean": "rimraf out dist",
    "typecheck": "tsc -p . --noEmit",
    "compile": "tsc -p . && node esbuild.config.mjs",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "tsc -p . && node esbuild.config.mjs --minify",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "test": "node node_modules/@vscode/test-cli/out/bin.mjs",
    "test:unit": "node node_modules/@vscode/test-cli/out/bin.mjs --label unit",
    "test:integration": "node node_modules/@vscode/test-cli/out/bin.mjs --label integration",
    "test:agent-harness": "npm run compile && node .tmp-test/run-agent-harness.cjs",
    "package": "vsce package"
  },
  "dependencies": {},
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@types/mocha": "10.0.10",
    "@types/node": "25.9.2",
    "@types/vscode": "1.104.0",
    "@vscode/test-cli": "0.0.10",
    "@vscode/test-electron": "3.0.0",
    "esbuild": "0.24.0",
    "eslint": "9.13.0",
    "mocha": "11.7.6",
    "prettier": "3.3.3",
    "rimraf": "6.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.12.2",
    "vsce": "2.15.0"
  }
}
