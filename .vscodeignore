# Internal-only paths that the `*.md` glob (which matches basenames
# only) leaves through. Each line below excludes every file under the
# prefix regardless of basename.
tasks/
docs/dev/

# Local scratch output (untracked); never an extension asset.
artifacts/

# Internal CI / scanner configs not meant to ship to the
# Marketplace.
.gitleaks.toml

# Logo variants not referenced by package.json `icon`, the README, or
# the CHANGELOG. `mighty_max_logo.png` (8.9 MB) was the prior hero
# image; the README now points at the lighter
# `mighty_max_logo_readme.png` (145 kB) so the heavy variant should
# never ship. The head2 PNGs are local inverted variants.
assets/img/mightymax_head2.png
assets/img/mightymax_head2_inv.png
assets/img/mighty_max_logo.png

# Regeneration tools: `widen-head.py` is a fontforge script that
# rebuilds `assets/fonts/mightymax.woff` from the pre-widened
# version in git HEAD. It's a developer convenience for future
# tweaks, not an extension asset.
assets/fonts/widen-head.py
